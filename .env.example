# ─────────────────────────────────────────────
# Rust 工具箱 · 环境变量配置
# 复制此文件为 .env 并填写真实值
# ─────────────────────────────────────────────

# ── FCM 配置（用于接收配对推送通知）────────────
# 通过 npx @liamcottle/rustplus.js fcm-register 自动生成
FCM_CREDENTIALS=

# ── Steam 配置（配对后自动写入，无需手动填写）──
STEAM_ID=
PLAYER_TOKEN=

# ── 通知渠道（可选）──────────────────────────
# Discord Webhook URL
DISCORD_WEBHOOK_URL=

# AI/翻译 API Key（Gemini，ai/fy 共用）
GEMINI_API_KEY=

# Gemini 模型（ai/fy 共用，默认 gemini-2.5-flash）
GEMINI_TRANSLATE_MODEL=gemini-2.5-flash

# ai/fy 共用每分钟最大请求次数（RPM）
FY_TRANSLATE_RPM=15

# Rust 队伍聊天单条最大字符数（用于 fy 返回截断）
RUST_TEAM_MESSAGE_MAX_CHARS=128
# GUI 手动发送队伍消息频率限制（每分钟）
GUI_TEAM_CHAT_RPM=20
# Web API 发送队伍消息频率限制（每分钟）
WEB_TEAM_CHAT_RPM=20

# 语音呼叫 API（可选，优先互亿无线，未配置时回退 Twilio）
IHUYI_VM_API_ID=
IHUYI_VM_API_KEY=
IHUYI_VM_ENDPOINT=https://api.ihuyi.com/vm/Submit.json
IHUYI_VM_FORMAT=json
IHUYI_VM_TEMPLATE_ID=

# 旧版语音呼叫 API（Twilio，可选回退）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── 程序配置 ───────────────────────────────
# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# WebSocket 心跳间隔（秒）
HEARTBEAT_INTERVAL=60

# 断线重连最大次数
MAX_RECONNECT=20

# 请求超时（毫秒）
REQUEST_TIMEOUT_MS=30000
# Gemini 请求超时（毫秒）
GEMINI_TIMEOUT_MS=15000
# 互亿无线语音请求超时（毫秒）
IHUYI_VM_TIMEOUT_MS=15000
# Twilio 请求超时（毫秒）
TWILIO_TIMEOUT_MS=15000

# 连续心跳失败达到该次数后，若长期无活动则触发重连
HEARTBEAT_FAIL_RECONNECT=8

# 判定连接僵死的活动宽限时间（毫秒）
ACTIVITY_GRACE_MS=90000

# ── Web 控制台（可选）────────────────────────
# Web 服务监听主机与端口
WEB_HOST=127.0.0.1
WEB_PORT=3080

# 启动时是否自动连接最后一次服务器（1=是，0=否）
WEB_AUTO_CONNECT=1

# Web API 访问令牌（默认强制要求）
WEB_API_TOKEN=change_me_to_a_long_random_token
# 是否强制 Web 鉴权（1=强制，0=关闭，不建议；留空时回环地址默认0，非回环地址默认1）
WEB_REQUIRE_API_TOKEN=1
